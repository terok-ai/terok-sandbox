module terok_socket 1.0;

# Targeted SELinux policy for terok service sockets.
#
# Defines ``terok_socket_t`` — a custom type that terok host services
# apply to their Unix sockets via ``setsockcreatecon()`` so that
# rootless Podman containers (``container_t``) can connect.
#
# Without this policy, SELinux denies ``container_t → unconfined_t``
# ``unix_stream_socket { connectto }`` — which is correct by design
# (Dan Walsh, Podman #23972).  This module narrows the exception to
# terok sockets only.
#
# Written in checkmodule-native module syntax (no refpolicy ``m4``
# macros), so the build path is ``checkmodule -M -m`` → ``semodule_package``
# → ``semodule -i`` without an m4 preprocessing step.
#
# Install:  sudo terok setup selinux
# Remove:   sudo semodule -r terok_socket

require {
    type container_t;
    class unix_stream_socket connectto;
}

type terok_socket_t;

allow container_t terok_socket_t:unix_stream_socket connectto;
